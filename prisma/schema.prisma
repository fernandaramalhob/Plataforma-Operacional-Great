generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String?
  avatarUrl          String?
  passwordHash       String
  role               Role             @default(MANAGER)
  metaAccessToken    String?
  metaTokenExpiresAt DateTime?
  createdAt          DateTime         @default(now())
  clients            Client[]
  reportSchedules    ReportSchedule[] @relation("ReportScheduleCreator")
}

model Client {
  id               String           @id @default(uuid())
  name             String
  company          String?
  email            String?
  phone            String?
  notes            String?
  whatsappGroupId  String?
  adAccountId      String?
  adAccountName    String?
  status           ClientStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now())
  managerId        String?
  manager          User?            @relation(fields: [managerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  campaigns        ClientCampaign[]
  reports          Report[]
  reportSchedule   ReportSchedule?
  weeklyDispatches WeeklyReportDispatch[]

  @@index([managerId, status])
  @@index([adAccountId])
}

model ReportSchedule {
  id              String                  @id @default(uuid())
  clientId        String                  @unique
  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByUserId String
  createdByUser   User                    @relation("ReportScheduleCreator", fields: [createdByUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  frequency       ReportScheduleFrequency
  weekday         Int?
  scheduledDate   DateTime?
  hour            Int
  minute          Int
  timeZone        String                  @default("America/Sao_Paulo")
  filtersSince    String
  filtersUntil    String
  objective       String                  @default("ALL")
  sendMode        String                  @default("PDF_AND_MESSAGE")
  message         String?
  groupId         String?
  active          Boolean                 @default(true)
  nextRunAt       DateTime
  lastRunAt       DateTime?
  last
}