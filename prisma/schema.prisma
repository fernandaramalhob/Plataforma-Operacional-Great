generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  name               String?
  avatarUrl          String?
  passwordHash       String
  role               Role             @default(MANAGER)
  metaAccessToken    String?
  metaTokenExpiresAt DateTime?
  evolutionInstance  String?
  createdAt          DateTime         @default(now())
  clients            Client[]
  reportSchedules    ReportSchedule[] @relation("ReportScheduleCreator")
}

model Client {
  id               String                 @id @default(uuid())
  name             String
  company          String?
  email            String?
  phone            String?
  notes            String?
  whatsappGroupId  String?
  adAccountId      String?
  adAccountName    String?
  status           ClientStatus           @default(ACTIVE)
  createdAt        DateTime               @default(now())
  managerId        String?
  manager          User?                  @relation(fields: [managerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  campaigns        ClientCampaign[]
  reports          Report[]
  reportSchedule   ReportSchedule?
  weeklyDispatches WeeklyReportDispatch[]

  @@index([managerId, status])
  @@index([adAccountId])
}

model ReportSchedule {
  id              String                  @id @default(uuid())
  clientId        String                  @unique
  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByUserId String
  createdByUser   User                    @relation("ReportScheduleCreator", fields: [createdByUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  frequency       ReportScheduleFrequency
  weekday         Int?
  scheduledDate   DateTime?
  hour            Int
  minute          Int
  timeZone        String                  @default("America/Sao_Paulo")
  filtersSince    String
  filtersUntil    String
  objective       String                  @default("ALL")
  sendMode        String                  @default("PDF_AND_MESSAGE")
  message         String?
  groupId         String?
  active          Boolean                 @default(true)
  nextRunAt       DateTime
  lastRunAt       DateTime?
  lastError       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([active, nextRunAt])
}

model ReportWorkerHeartbeat {
  id              String   @id
  startedAt       DateTime @default(now())
  lastHeartbeatAt DateTime
  lastError       String?
  lastAlertAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClientCampaign {
  id             String  @id @default(uuid())
  clientId       String
  client         Client  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  campaignIdMeta String
  campaignName   String
  isActive       Boolean @default(true)

  @@unique([clientId, campaignIdMeta])
  @@index([clientId, isActive])
}

model Report {
  id               String                 @id @default(uuid())
  clientId         String
  client           Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referenceWeek    DateTime
  generatedAt      DateTime               @default(now())
  status           ReportStatus           @default(PENDING)
  payloadJson      Json?
  sendLogs         SendLog[]
  weeklyDispatches WeeklyReportDispatch[]

  @@index([clientId, generatedAt])
  @@index([status, generatedAt])
  @@index([referenceWeek])
}

model SendLog {
  id            String        @id @default(uuid())
  reportId      String
  report        Report        @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  channel       String
  status        SendLogStatus @default(PENDING)
  sentAt        DateTime?
  errorMessage  String?
  attemptNumber Int           @default(1)

  @@unique([reportId, attemptNumber])
  @@index([reportId, status])
  @@index([sentAt])
}

model WeeklyReportDispatch {
  id                  String                     @id @default(uuid())
  clientId            String
  client              Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reportId            String?
  report              Report?                    @relation(fields: [reportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reportWeekKey       String
  filtersSince        String
  filtersUntil        String
  timeZone            String
  status              WeeklyReportDispatchStatus @default(PROCESSING)
  sentAt              DateTime?
  errorMessage        String?
  attemptCount        Int                        @default(0)
  lastAttemptAt       DateTime?
  processingToken     String?
  processingStartedAt DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([clientId, reportWeekKey])
  @@index([reportWeekKey, status])
  @@index([status, updatedAt])
}

enum Role {
  ADMIN
  MANAGER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum ReportStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum SendLogStatus {
  PENDING
  OK
  FAILED
}

enum ReportScheduleFrequency {
  ONCE
  WEEKLY
}

enum WeeklyReportDispatchStatus {
  PROCESSING
  SENT
  FAILED
  SKIPPED
}
