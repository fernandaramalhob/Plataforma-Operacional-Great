# Defaults nao sensiveis apenas.
# Segredos locais devem ficar em `.env.local`.
NEXTAUTH_URL="http://localhost:3000"

# Segredos locais somente para desenvolvimento.
# Nao reutilize tokens da META, chaves de API ou senhas como `NEXTAUTH_SECRET`.
# Use valores independentes para `NEXTAUTH_SECRET` e `META_TOKEN_ENCRYPTION_KEY`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
NEXTAUTH_SECRET="gere_um_valor_hex_ou_base64_forte"
META_TOKEN_ENCRYPTION_KEY="gere_outro_valor_hex_ou_base64_forte"
DEV_BYPASS_AUTH="false"
EVOLUTION_API_URL="https://sua-instancia-evolution.exemplo"
EVOLUTION_API_KEY="sua-chave-local"
EVOLUTION_INSTANCE="GreatGo"
REPORT_AUTOMATION_BASE_URL="http://localhost:3000"
REPORT_AUTOMATION_EMAIL="tecnico@greatgo.com"
REPORT_AUTOMATION_PASSWORD=""
REPORT_AUTOMATION_TIMEZONE="America/Sao_Paulo"
REPORT_AUTOMATION_OBJECTIVE="ALL"
REPORT_AUTOMATION_SEND_MODE="PDF_AND_MESSAGE"
REPORT_AUTOMATION_GROUP_ID=""
REPORT_AUTOMATION_CONNECTED_ONLY="true"
REPORT_AUTOMATION_MAX_CLIENTS=""
REPORT_AUTOMATION_REQUEST_TIMEOUT_SECONDS="30"
REPORT_AUTOMATION_REQUEST_MAX_RETRIES="3"
REPORT_AUTOMATION_RETRY_BACKOFF_SECONDS="3"
REPORT_AUTOMATION_POLL_INTERVAL_SECONDS="5"
REPORT_AUTOMATION_POLL_MAX_ATTEMPTS="24"
REPORT_AUTOMATION_SKIP_IF_ALREADY_SENT="true"
REPORT_AUTOMATION_DAEMON_POLL_SECONDS="5"
REPORT_AUTOMATION_DAEMON_RETRY_MINUTES="15"
REPORT_WEEKLY_CRON="0 9 * * 4"
REPORT_WEEKLY_TZ="America/Sao_Paulo"
REPORT_SCHEDULE_POLL_SECONDS="5"

# Opcional: usados apenas pelo script `npm run user:create`
SEED_USER_EMAIL="admin@greatgo.com"
SEED_USER_PASSWORD=""
SEED_USER_ROLE="ADMIN"
