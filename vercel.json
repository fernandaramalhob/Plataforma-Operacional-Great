{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd operacional-great && npm ci",
  "buildCommand": "cd operacional-great && npm run build",
  "outputDirectory": "operacional-great/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
