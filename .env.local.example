# Exemplo local sem segredos reais.
# Copie para `.env.local` e troque os valores antes de rodar em um ambiente real.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/greatgo?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/greatgo?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-um-secret-forte"
REPORT_PDF_RENDER_SECRET="troque-por-outro-secret-forte"
META_TOKEN_ENCRYPTION_KEY="troque-por-outra-chave-forte"

ADMIN_EMAIL="admin@greatgo.com"
ADMIN_PASSWORD="troque-esta-senha"

META_APP_ID=""
META_APP_SECRET=""

EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="GreatGo"
REPORT_AUTOMATION_BASE_URL="http://localhost:3000"
REPORT_AUTOMATION_EMAIL="tecnico@greatgo.com"
REPORT_AUTOMATION_PASSWORD="troque-esta-senha"
REPORT_AUTOMATION_TIMEZONE="America/Sao_Paulo"
REPORT_AUTOMATION_OBJECTIVE="ALL"
REPORT_AUTOMATION_SEND_MODE="PDF_AND_MESSAGE"
REPORT_AUTOMATION_GROUP_ID=""
REPORT_AUTOMATION_CONNECTED_ONLY="true"
REPORT_AUTOMATION_MAX_CLIENTS=""
REPORT_AUTOMATION_REQUEST_TIMEOUT_SECONDS="30"
REPORT_AUTOMATION_REQUEST_MAX_RETRIES="3"
REPORT_AUTOMATION_RETRY_BACKOFF_SECONDS="3"
REPORT_AUTOMATION_POLL_INTERVAL_SECONDS="5"
REPORT_AUTOMATION_POLL_MAX_ATTEMPTS="24"
REPORT_AUTOMATION_SKIP_IF_ALREADY_SENT="true"
REPORT_AUTOMATION_DAEMON_POLL_SECONDS="5"
REPORT_AUTOMATION_DAEMON_RETRY_MINUTES="15"

REDIS_URL="redis://localhost:6379"
REPORT_QUEUE_PREFIX="greatgo"
REPORT_PROCESS_BATCH_SIZE="5"
REPORT_PROCESS_LOCK_TTL_SECONDS="300"
REPORT_WEEKLY_CRON="0 9 * * 4"
REPORT_WEEKLY_TZ="America/Sao_Paulo"
REPORT_SCHEDULE_POLL_SECONDS="5"
REPORT_WEEKLY_BATCH_SIZE="10"
REPORT_WEEKLY_OBJECTIVE="ALL"
REPORT_ALERTS_RETENTION="50"
INTEGRATION_ALERTS_RETENTION="50"
INTEGRATION_ALERT_DEDUPE_TTL_SECONDS="3600"
CRON_SECRET="troque-por-um-secret-para-o-vercel-cron"

